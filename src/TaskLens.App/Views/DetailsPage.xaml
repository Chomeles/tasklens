<Page
  x:Class="TaskLens.App.Views.DetailsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views">

  <StackPanel Margin="24,12" Spacing="20">
    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.ProcessName, Mode=OneWay}" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Width="120" VerticalAlignment="Center" Text="Process CPU:" />
      <Polyline
        Width="400"
        Height="80"
        Points="{x:Bind views:SparklineRender.Points(ViewModel.ProcessCpuHistory, 400, 80), Mode=OneWay}"
        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
        StrokeThickness="1.5" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Width="120" VerticalAlignment="Center" Text="System CPU:" />
      <Polyline
        Width="400"
        Height="80"
        Points="{x:Bind views:SparklineRender.Points(ViewModel.SystemCpuHistory, 400, 80), Mode=OneWay}"
        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
        StrokeThickness="1.5" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Width="120" VerticalAlignment="Center" Text="System Memory:" />
      <Polyline
        Width="400"
        Height="80"
        Points="{x:Bind views:SparklineRender.Points(ViewModel.SystemMemoryHistory, 400, 80), Mode=OneWay}"
        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
        StrokeThickness="1.5" />
    </StackPanel>
  </StackPanel>
</Page>
