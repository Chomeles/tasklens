<Page
  x:Class="TaskLens.App.Views.SensorsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" RowSpacing="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Degradation banner: no admin / no PawnIO / no sensors (VM). -->
    <InfoBar
      Grid.Row="0"
      IsClosable="False"
      IsOpen="{x:Bind ViewModel.ShowBanner, Mode=OneWay}"
      Message="{x:Bind ViewModel.BannerText, Mode=OneWay}"
      Severity="Warning" />

    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{x:Bind ViewModel.Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:HardwareGroupViewModel">
            <StackPanel Margin="0,0,0,20">
              <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind Name}" />
              <ItemsControl Margin="0,8,0,0" ItemsSource="{x:Bind Sensors}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SensorRowViewModel">
                    <Grid Padding="12,4" ColumnSpacing="8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="96" />
                      </Grid.ColumnDefinitions>
                      <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="{x:Bind Name}"
                        TextTrimming="CharacterEllipsis" />
                      <Polyline
                        Grid.Column="1"
                        Width="140"
                        Height="24"
                        Points="{x:Bind views:SparklineRender.Points(History, 140, 24), Mode=OneWay}"
                        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                        StrokeThickness="1.5" />
                      <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="{x:Bind ValueText, Mode=OneWay}"
                        TextAlignment="Right" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Page>
