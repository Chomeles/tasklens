<Page
  x:Class="Taskmanager2.App.Views.AutostartPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Degradation as data: access denied shows a banner instead of throwing (plan-tm2.md §2). -->
    <InfoBar
      Grid.Row="0"
      IsClosable="False"
      IsOpen="{x:Bind ViewModel.ShowBanner, Mode=OneWay}"
      Message="{x:Bind ViewModel.BannerText, Mode=OneWay}"
      Severity="Warning" />

    <!-- Real TM page header: big title left, action button right (tm3-06). -->
    <Grid Grid.Row="1" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="Autostart-Apps" />
      <Button
        Grid.Column="1"
        Command="{x:Bind ViewModel.ToggleSelectedCommand}"
        Content="{x:Bind ViewModel.ToggleButtonText, Mode=OneWay}"
        Style="{StaticResource AccentButtonStyle}" />
    </Grid>

    <InfoBar
      Grid.Row="2"
      CloseButtonClick="OnErrorClosed"
      IsOpen="{x:Bind ViewModel.HasActionError, Mode=OneWay}"
      Message="{x:Bind ViewModel.LastActionError, Mode=OneWay}"
      Severity="Error"
      Title="Autostart-Eintrag konnte nicht geändert werden" />

    <!-- Fixed order: alphabetisch nach Name — keine Sortier-UI. -->
    <Grid Grid.Row="3" Padding="12,0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="200" />
        <ColumnDefinition Width="110" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Name" />
      <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Befehl" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Quelle" />
      <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Status" />
    </Grid>

    <ListView
      Grid.Row="4"
      ItemsSource="{x:Bind ViewModel.Rows}"
      SelectionChanged="OnSelectionChanged"
      SelectionMode="Single">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="12,2" />
          <Setter Property="MinHeight" Value="0" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:Tm2StartupRowViewModel">
          <Grid Background="Transparent" ColumnSpacing="8">
            <Grid.ContextFlyout>
              <MenuFlyout>
                <MenuFlyoutItem Click="OnToggleClick" Text="Aktivieren/Deaktivieren" />
              </MenuFlyout>
            </Grid.ContextFlyout>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="220" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="200" />
              <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Command, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Source}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind StatusText, Mode=OneWay}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Page>
