<Window
  x:Class="Taskmanager2.App.Views.Shell"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Taskmanager2">

  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- First-run install hint: shown once at startup when the PawnIO driver is missing. -->
    <InfoBar
      Grid.Row="0"
      IsClosable="True"
      IsOpen="{x:Bind BannerViewModel.ShowBanner, Mode=OneWay}"
      Message="{x:Bind BannerViewModel.BannerText, Mode=OneWay}"
      Severity="Informational" />

    <NavigationView
      Grid.Row="1"
      x:Name="Nav"
      IsBackButtonVisible="Collapsed"
      IsSettingsVisible="True"
      PaneDisplayMode="LeftCompact"
      IsPaneToggleButtonVisible="True"
      SelectionChanged="OnSelectionChanged">
      <NavigationView.MenuItems>
        <NavigationViewItem Content="Prozesse" Tag="Prozesse">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE9D9;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Leistung" Tag="Leistung">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE9D2;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="App-Verlauf" Tag="AppVerlauf">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE81C;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Autostart-Apps" Tag="Autostart">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE7E8;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Benutzer" Tag="Benutzer">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE77B;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Details" Tag="Details">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE946;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Dienste" Tag="Dienste">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE90F;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>
      <Frame x:Name="ContentFrame" />
    </NavigationView>
  </Grid>
</Window>
