<Page
  x:Class="Taskmanager2.App.Views.EinstellungenPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Page.Resources>
    <!-- Win11 settings card: rounded surface, text left, control right. -->
    <Style x:Key="SettingCard" TargetType="Grid">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
      <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="ColumnSpacing" Value="16" />
    </Style>
  </Page.Resources>

  <ScrollViewer>
    <StackPanel Margin="16,8,16,24" MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="8">
      <!-- Real TM page header: big title left, like every Win11 TM page. -->
      <TextBlock Margin="0,0,0,8" FontSize="20" FontWeight="SemiBold" Text="Einstellungen" />

      <Grid Style="{StaticResource SettingCard}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="App-Theme" />
          <TextBlock FontSize="12" Opacity="0.7" Text="Wählen Sie das anzuzeigende App-Theme aus" />
        </StackPanel>
        <ComboBox Grid.Column="1" MinWidth="160" VerticalAlignment="Center"
                  SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
          <ComboBoxItem Content="Systemeinstellung verwenden" />
          <ComboBoxItem Content="Hell" />
          <ComboBoxItem Content="Dunkel" />
        </ComboBox>
      </Grid>

      <Grid Style="{StaticResource SettingCard}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="Echtzeitaktualisierungsgeschwindigkeit" />
          <TextBlock FontSize="12" Opacity="0.7" Text="Wie oft die Prozess- und Sensorwerte neu abgetastet werden" />
        </StackPanel>
        <ComboBox Grid.Column="1" x:Name="SpeedBox" MinWidth="160" VerticalAlignment="Center" SelectionChanged="OnSpeedChanged">
          <ComboBoxItem Content="Hoch" />
          <ComboBoxItem Content="Normal" />
          <ComboBoxItem Content="Niedrig" />
        </ComboBox>
      </Grid>

      <Grid Style="{StaticResource SettingCard}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="Temperatureinheit" />
          <TextBlock FontSize="12" Opacity="0.7" Text="Anzeige der CPU-Temperatur in den Sensor-Spalten" />
        </StackPanel>
        <ComboBox Grid.Column="1" MinWidth="160" VerticalAlignment="Center"
                  SelectedIndex="{x:Bind ViewModel.TemperatureUnitIndex, Mode=TwoWay}">
          <ComboBoxItem Content="Celsius" />
          <ComboBoxItem Content="Fahrenheit" />
        </ComboBox>
      </Grid>

      <Grid Style="{StaticResource SettingCard}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="CPU-Auslastung normalisieren" />
          <TextBlock FontSize="12" Opacity="0.7" Text="100 % = ganze Maschine oder 100 % = ein Kern" />
        </StackPanel>
        <ComboBox Grid.Column="1" MinWidth="160" VerticalAlignment="Center"
                  SelectedIndex="{x:Bind ViewModel.CpuNormalizationIndex, Mode=TwoWay}">
          <ComboBoxItem Content="Alle Kerne" />
          <ComboBoxItem Content="Ein Kern" />
        </ComboBox>
      </Grid>

      <Grid Style="{StaticResource SettingCard}">
        <StackPanel Spacing="2">
          <TextBlock Text="Info" />
          <TextBlock FontSize="12" Opacity="0.7"
                     Text="Taskmanager2 — Layout-Hommage an den Windows-11-Task-Manager mit allen Sensorwerten, die er versteckt. Keine Microsoft-Assets." />
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Page>
