<Page
  x:Class="Taskmanager2.App.Views.DetailsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:TaskLens.Core.ViewModels"
  xmlns:svc="using:Taskmanager2.App.Services">

  <Grid Margin="24,12" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Real TM page header: big title left, „Neuen Task ausführen" right (tm3-10). -->
    <Grid Grid.Row="0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="Details" />
      <Button Grid.Column="1" Click="OnRunTaskClick" Style="{StaticResource AccentButtonStyle}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon FontSize="14" Glyph="&#xE710;" />
            <TextBlock Text="Neuen Task ausführen" />
          </StackPanel>
        </Button>
    </Grid>

    <!-- Dense table, real Win11 Details page column order: Name, PID, Status, Benutzername,
         CPU, Arbeitsspeicher, Architektur, Befehlszeile — owner/architecture/command line are real
         token/IsWow64Process2/NtQueryInformationProcess reads, em-dash (command line: empty) when
         the process can't be opened (never fabricated). -->
    <Grid Grid.Row="1" Padding="12,0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="64" />
        <ColumnDefinition Width="90" />
        <ColumnDefinition Width="130" />
        <ColumnDefinition Width="64" />
        <ColumnDefinition Width="110" />
        <ColumnDefinition Width="90" />
        <ColumnDefinition Width="200" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" HorizontalAlignment="Stretch" Tag="Name" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('Name', 'Name', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="1" HorizontalAlignment="Stretch" Tag="Pid" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('PID', 'Pid', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}" />
      <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Status" />
      <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Benutzername" />
      <Button Grid.Column="4" HorizontalAlignment="Stretch" Tag="Cpu" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('CPU', 'Cpu', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="5" HorizontalAlignment="Stretch" Tag="Memory" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('Arbeitsspeicher', 'Memory', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
              ToolTipService.ToolTip="Aktiver privater Arbeitssatz" />
      <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="Architektur" />
      <TextBlock Grid.Column="7" VerticalAlignment="Center" Text="Befehlszeile" />
    </Grid>

    <ListView
      Grid.Row="2"
      ItemsSource="{x:Bind ViewModel.Rows}"
      SelectionMode="Single">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="12,1" />
          <Setter Property="MinHeight" Value="0" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:ProcessRowViewModel">
          <Grid Background="Transparent" ColumnSpacing="8">
            <Grid.ContextFlyout>
              <!-- Real TM Details menu: Priorität festlegen (tm3-05-extended). Task beenden lives
                   on the Prozesse page; here the priority submenu is the headline action. -->
              <MenuFlyout>
                <MenuFlyoutSubItem Text="Priorität festlegen">
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="Realtime" Text="Echtzeit" />
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="High" Text="Hoch" />
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="AboveNormal" Text="Höher als normal" />
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="Normal" Text="Normal" />
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="BelowNormal" Text="Niedriger als normal" />
                  <MenuFlyoutItem Click="OnPriorityClick" Tag="Idle" Text="Niedrig" />
                </MenuFlyoutSubItem>
              </MenuFlyout>
            </Grid.ContextFlyout>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Pid}" TextAlignment="Right" />
            <!-- ponytail: Status-Zelle bleibt leer — keine Suspend-Detection in Core. -->
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind UserNameText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <Border Grid.Column="4" Background="{x:Bind svc:CellHeat.Brush(CpuPercent), Mode=OneWay}">
              <TextBlock VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Percent(CpuPercent), Mode=OneWay}" TextAlignment="Right" />
            </Border>
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Bytes(WorkingSetBytes), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="{x:Bind ArchitectureText, Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="7" VerticalAlignment="Center" Text="{x:Bind CommandLineText, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Page>
