<Page
  x:Class="Taskmanager2.App.Views.LeistungPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" ColumnSpacing="16" RowSpacing="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="248" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Sensor degradation banner: no admin / no PawnIO / no sensors (VM). -->
    <InfoBar
      Grid.Row="0"
      Grid.Column="0"
      Grid.ColumnSpan="2"
      IsClosable="False"
      IsOpen="{x:Bind ViewModel.Sensors.ShowBanner, Mode=OneWay}"
      Message="{x:Bind ViewModel.Sensors.BannerText, Mode=OneWay}"
      Severity="Warning" />

    <!-- Left rail: CPU, Arbeitsspeicher, Datenträger, GPU + one entry per sensor hardware group. -->
    <ListView
      x:Name="Rail"
      Grid.Row="1"
      Grid.Column="0"
      ItemsSource="{x:Bind ViewModel.Entries}"
      SelectionChanged="OnRailSelectionChanged"
      SelectionMode="Single">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:Tm2PerformanceEntryViewModel">
          <Grid Padding="0,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Polyline
              Grid.Column="0"
              Width="64"
              Height="36"
              VerticalAlignment="Center"
              Points="{x:Bind views:SparklineRender.Points(History, 64, 36), Mode=OneWay}"
              Stroke="{ThemeResource AccentFillColorDefaultBrush}"
              StrokeThickness="1" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
              <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ValueText, Mode=OneWay}" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Main panel: big history graph + every sensor reading of the selected group. -->
    <ScrollViewer Grid.Row="1" Grid.Column="1">
      <StackPanel Spacing="12">
        <TextBlock
          Style="{StaticResource TitleTextBlockStyle}"
          Text="{x:Bind ViewModel.SelectedEntry.Name, Mode=OneWay}" />
        <TextBlock
          Style="{StaticResource SubtitleTextBlockStyle}"
          Text="{x:Bind ViewModel.SelectedEntry.ValueText, Mode=OneWay}" />
        <Border
          Height="220"
          HorizontalAlignment="Stretch"
          BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
          BorderThickness="1">
          <Polyline
            Width="560"
            Height="200"
            VerticalAlignment="Center"
            Points="{x:Bind views:SparklineRender.Points(ViewModel.SelectedEntry.History, 560, 200), Mode=OneWay}"
            Stroke="{ThemeResource AccentFillColorDefaultBrush}"
            StrokeThickness="1.5" />
        </Border>
        <!-- Null ItemsSource for the four system entries — the list is simply empty. -->
        <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedEntry.Sensors, Mode=OneWay}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SensorRowViewModel">
              <Grid Padding="0,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="200" />
                  <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  Text="{x:Bind Name}"
                  TextTrimming="CharacterEllipsis" />
                <Polyline
                  Grid.Column="1"
                  Width="200"
                  Height="32"
                  Points="{x:Bind views:SparklineRender.Points(History, 200, 32), Mode=OneWay}"
                  Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                  StrokeThickness="1" />
                <TextBlock
                  Grid.Column="2"
                  VerticalAlignment="Center"
                  Text="{x:Bind ValueText, Mode=OneWay}"
                  TextAlignment="Right" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
