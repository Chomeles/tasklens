<Page
  x:Class="Taskmanager2.App.Views.LeistungPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" ColumnSpacing="16" RowSpacing="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="248" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Real TM page header: big title left, „Neuen Task ausführen" right (tm3-10). -->
    <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="Leistung" />
      <Button Grid.Column="1" Click="OnRunTaskClick" Style="{StaticResource AccentButtonStyle}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon FontSize="14" Glyph="&#xE710;" />
            <TextBlock Text="Neuen Task ausführen" />
          </StackPanel>
        </Button>
    </Grid>

    <!-- Sensor degradation banner: no admin / no PawnIO / no sensors (VM). -->
    <InfoBar
      Grid.Row="1"
      Grid.Column="0"
      Grid.ColumnSpan="2"
      IsClosable="False"
      IsOpen="{x:Bind ViewModel.Sensors.ShowBanner, Mode=OneWay}"
      Message="{x:Bind ViewModel.Sensors.BannerText, Mode=OneWay}"
      Severity="Warning" />

    <!-- Left rail: CPU, Arbeitsspeicher, Datenträger, GPU + one entry per sensor hardware group. -->
    <ListView
      x:Name="Rail"
      Grid.Row="2"
      Grid.Column="0"
      ItemsSource="{x:Bind ViewModel.Entries}"
      SelectionChanged="OnRailSelectionChanged"
      SelectionMode="Single">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:Tm2PerformanceEntryViewModel">
          <Grid Padding="0,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Polyline
              Grid.Column="0"
              Width="64"
              Height="36"
              VerticalAlignment="Center"
              Points="{x:Bind views:SparklineRender.Points(History, 64, 36), Mode=OneWay}"
              Stroke="{ThemeResource AccentFillColorDefaultBrush}"
              StrokeThickness="1" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
              <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ValueText, Mode=OneWay}" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Main panel: big history graph + every sensor reading of the selected group. -->
    <ScrollViewer Grid.Row="2" Grid.Column="1">
      <StackPanel Spacing="12">
        <TextBlock
          Style="{StaticResource TitleTextBlockStyle}"
          Text="{x:Bind ViewModel.SelectedEntry.Name, Mode=OneWay}" />
        <TextBlock
          Style="{StaticResource SubtitleTextBlockStyle}"
          Text="{x:Bind ViewModel.SelectedEntry.ValueText, Mode=OneWay}" />
        <Border
          Height="220"
          HorizontalAlignment="Stretch"
          BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
          BorderThickness="1">
          <Polyline
            Width="560"
            Height="200"
            VerticalAlignment="Center"
            Points="{x:Bind views:SparklineRender.Points(ViewModel.SelectedEntry.History, 560, 200), Mode=OneWay}"
            Stroke="{ThemeResource AccentFillColorDefaultBrush}"
            StrokeThickness="1.5" />
        </Border>
        <!-- CPU facts like the real TM: ticking Betriebszeit + logical processor count. -->
        <Grid ColumnSpacing="32" Visibility="{x:Bind ViewModel.IsCpuSelected, Mode=OneWay}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Betriebszeit" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.UptimeText, Mode=OneWay}" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Logische Prozessoren" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.LogicalProcessorsText}" />
          </StackPanel>
        </Grid>

        <!-- Disk facts (tm3-05, honest subset): read/write rates from per-process IO sums,
             capacity from DriveInfo. Aktive Zeit/Antwortzeit bräuchten PDH-Disk-Counter — offen. -->
        <Grid ColumnSpacing="32" Visibility="{x:Bind ViewModel.IsDiskSelected, Mode=OneWay}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Aktive Zeit" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.DiskActiveText, Mode=OneWay}" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Durchschnittliche Antwortzeit" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.DiskResponseText, Mode=OneWay}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Lesegeschwindigkeit" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.DiskReadText, Mode=OneWay}" />
          </StackPanel>
          <StackPanel Grid.Column="3">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Schreibgeschwindigkeit" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.DiskWriteText, Mode=OneWay}" />
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Kapazität" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.DiskCapacityText}" />
          </StackPanel>
        </Grid>

        <!-- Arbeitsspeicher detail panel (tm3-03): composition bar + the real TM value block. -->
        <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.IsMemorySelected, Mode=OneWay}">
          <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Speicherzusammensetzung" />
          <Border
            Width="560"
            Height="24"
            HorizontalAlignment="Left"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="1">
            <Rectangle
              Width="{x:Bind views:SparklineRender.Fraction(ViewModel.MemoryDetails.UsedFraction, 558), Mode=OneWay}"
              HorizontalAlignment="Left"
              Fill="{ThemeResource AccentFillColorDefaultBrush}"
              Opacity="0.6" />
          </Border>
          <Grid ColumnSpacing="32" RowSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
              <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="In Verwendung" />
              <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.MemoryDetails.InUseText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1">
              <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Verfügbar" />
              <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind ViewModel.MemoryDetails.AvailableText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0">
              <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Zugesichert" />
              <TextBlock Text="{x:Bind ViewModel.MemoryDetails.CommittedText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Im Cache" />
              <TextBlock Text="{x:Bind ViewModel.MemoryDetails.CachedText, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2">
              <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Ausgelagerter Pool / Nicht ausgelagerter Pool" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.MemoryDetails.PagedPoolText, Mode=OneWay}" />
                <TextBlock Text="/" />
                <TextBlock Text="{x:Bind ViewModel.MemoryDetails.NonPagedPoolText, Mode=OneWay}" />
              </StackPanel>
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Null ItemsSource for the four system entries — the list is simply empty. -->
        <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedEntry.Sensors, Mode=OneWay}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SensorRowViewModel">
              <Grid Padding="0,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="200" />
                  <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  Text="{x:Bind Name}"
                  TextTrimming="CharacterEllipsis" />
                <Polyline
                  Grid.Column="1"
                  Width="200"
                  Height="32"
                  Points="{x:Bind views:SparklineRender.Points(History, 200, 32), Mode=OneWay}"
                  Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                  StrokeThickness="1" />
                <TextBlock
                  Grid.Column="2"
                  VerticalAlignment="Center"
                  Text="{x:Bind ValueText, Mode=OneWay}"
                  TextAlignment="Right" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
