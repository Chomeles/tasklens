<Page
  x:Class="Taskmanager2.App.Views.ProzessePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBox
      Grid.Row="0"
      MaxWidth="420"
      HorizontalAlignment="Left"
      PlaceholderText="Geben Sie zum Suchen einen Namen, einen Herausgeber oder eine PID ein"
      Text="{x:Bind ViewModel.Inner.Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

    <!-- Header: sortable columns route to Inner.SortBy (Tag = ProcessColumn name). The sensor
         columns (Temperatur/Leistung/Lüfter) carry the same system-wide value on every row and
         Status/Verlauf have nothing to order by — plain labels, no sort. -->
    <Grid Grid.Row="1" Padding="12,0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="56" />
        <ColumnDefinition Width="64" />
        <ColumnDefinition Width="64" />
        <ColumnDefinition Width="64" />
        <ColumnDefinition Width="110" />
        <ColumnDefinition Width="90" />
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="90" />
        <ColumnDefinition Width="132" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" HorizontalAlignment="Stretch" Tag="Name" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('Name', 'Name', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="1" HorizontalAlignment="Stretch" Tag="Pid" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('PID', 'Pid', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Status" />
      <Button Grid.Column="3" HorizontalAlignment="Stretch" Tag="Cpu" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('CPU %', 'Cpu', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="4" HorizontalAlignment="Stretch" Tag="Gpu" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('GPU %', 'Gpu', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="5" HorizontalAlignment="Stretch" Tag="Memory" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('Arbeitsspeicher', 'Memory', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <Button Grid.Column="6" HorizontalAlignment="Stretch" Tag="Disk" Click="OnSortHeaderClick"
              Content="{x:Bind vm:ProcessFormat.Header('Datenträger', 'Disk', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      <TextBlock Grid.Column="7" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Temperatur" />
      <TextBlock Grid.Column="8" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Leistung (W)" />
      <TextBlock Grid.Column="9" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Lüfter (RPM)" />
      <TextBlock Grid.Column="10" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Verlauf" />
    </Grid>

    <ListView
      Grid.Row="2"
      ItemsSource="{x:Bind ViewModel.Rows}"
      SelectionMode="None">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="12,2" />
          <Setter Property="MinHeight" Value="0" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:Tm2ProcessRowViewModel">
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="56" />
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="132" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Pid}" TextAlignment="Right" />
            <!-- ponytail: Status-Zellen bleiben leer — Core hat keine Suspend-Detection, und der echte
                 Win11-TM zeigt hier für die meisten Prozesse auch nichts. Detection nur bauen, wenn
                 eine Task es fordert. -->
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Percent(CpuPercent), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Percent(GpuPercent), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Bytes(WorkingSetBytes), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.DiskRate(IoReadBytesPerSecond, IoWriteBytesPerSecond), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="7" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Temperature(CpuTempCelsius), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="8" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Power(PackageWattage), Mode=OneWay}" TextAlignment="Right" />
            <TextBlock Grid.Column="9" VerticalAlignment="Center" Text="{x:Bind vm:ProcessFormat.Fan(FanRpm), Mode=OneWay}" TextAlignment="Right" />
            <Polyline
              Grid.Column="10"
              Width="120"
              Height="20"
              VerticalAlignment="Center"
              Points="{x:Bind views:SparklineRender.Points(CpuHistory, 120, 20), Mode=OneWay}"
              Stroke="{ThemeResource AccentFillColorDefaultBrush}"
              StrokeThickness="1" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Page>
