<Page
  x:Class="Taskmanager2.App.Views.ProzessePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:TaskLens.App.Views"
  xmlns:vm="using:TaskLens.Core.ViewModels"
  xmlns:svc="using:Taskmanager2.App.Services">

  <Page.Resources>
    <svc:BoolToVisibilityConverter x:Key="BoolToVis" />

    <!-- Real TM column grid, shared by header and rows so they stay aligned. Win11 columns first
         (Name/Status/CPU/Arbeitsspeicher/Datenträger/Netzwerk), then the density-satire columns
         (GPU/Temperatur/Leistung/Lüfter/Verlauf) styled like native optional columns. -->
    <x:Double x:Key="StatusWidth">70</x:Double>
    <x:Double x:Key="CpuWidth">84</x:Double>
    <x:Double x:Key="MemWidth">100</x:Double>
    <x:Double x:Key="DiskWidth">100</x:Double>
    <x:Double x:Key="NetWidth">90</x:Double>
    <x:Double x:Key="GpuWidth">70</x:Double>
    <x:Double x:Key="TempWidth">80</x:Double>
    <x:Double x:Key="WattWidth">80</x:Double>
    <x:Double x:Key="FanWidth">80</x:Double>
    <x:Double x:Key="TrendWidth">132</x:Double>

    <!-- Sortable header cell: transparent flat button, content bottom-right like the real app. -->
    <Style x:Key="HeaderCellButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,1,0" />
      <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
      <Setter Property="VerticalContentAlignment" Value="Bottom" />
    </Style>
  </Page.Resources>

  <Grid Margin="16,8,16,0" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Real Win11 top bar: „Neuen Task ausführen" (accent, echter Dialog) / „Task beenden" /
         „Effizienzmodus" (echtes EcoQoS) / „…" — alle Aktionen real seit tm3-01/tm3-02. -->
    <Grid Grid.Row="0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <!-- Search lives in the Shell header like the real TM; this row keeps only the page title
           and action buttons, mirroring the Win11 layout. -->
      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="Prozesse" />
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Click="OnRunTaskClick" Style="{StaticResource AccentButtonStyle}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon FontSize="14" Glyph="&#xE710;" />
            <TextBlock Text="Neuen Task ausführen" />
          </StackPanel>
        </Button>
        <Button Command="{x:Bind ViewModel.EndTaskCommand}" Content="Task beenden" />
        <Button Command="{x:Bind ViewModel.EfficiencyCommand}" Content="Effizienzmodus" />
        <Button Padding="8,6">
          <FontIcon FontSize="14" Glyph="&#xE712;" />
        </Button>
      </StackPanel>
    </Grid>


    <InfoBar
      Grid.Row="1"
      CloseButtonClick="OnErrorClosed"
      IsOpen="{x:Bind ViewModel.HasActionError, Mode=OneWay}"
      Message="{x:Bind ViewModel.LastActionError, Mode=OneWay}"
      Severity="Error"
      Title="Aktion fehlgeschlagen" />

    <!-- Authentic header row: metric columns show the big system aggregate over the small column
         label, cell tinted by the same heat ramp as the rows; clicking sorts via Inner.SortBy. -->
    <Grid Grid.Row="2" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="{StaticResource StatusWidth}" />
        <ColumnDefinition Width="{StaticResource CpuWidth}" />
        <ColumnDefinition Width="{StaticResource MemWidth}" />
        <ColumnDefinition Width="{StaticResource DiskWidth}" />
        <ColumnDefinition Width="{StaticResource NetWidth}" />
        <ColumnDefinition Width="{StaticResource GpuWidth}" />
        <ColumnDefinition Width="{StaticResource TempWidth}" />
        <ColumnDefinition Width="{StaticResource WattWidth}" />
        <ColumnDefinition Width="{StaticResource FanWidth}" />
        <ColumnDefinition Width="{StaticResource TrendWidth}" />
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Style="{StaticResource HeaderCellButton}" HorizontalContentAlignment="Left"
              Tag="Name" Click="OnSortHeaderClick">
        <TextBlock FontSize="12" Opacity="0.8"
                   Text="{x:Bind vm:ProcessFormat.Header('Name', 'Name', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
      </Button>
      <TextBlock Grid.Column="1" Margin="8,0,8,4" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" Text="Status" />
      <Button Grid.Column="2" Style="{StaticResource HeaderCellButton}" Tag="Cpu" Click="OnSortHeaderClick"
              Background="{x:Bind svc:CellHeat.Brush(ViewModel.Inner.SystemCpuPercent), Mode=OneWay}">
        <StackPanel>
          <TextBlock HorizontalAlignment="Right" FontSize="14"
                     Text="{x:Bind vm:ProcessFormat.HeaderPercent(ViewModel.Inner.SystemCpuPercent), Mode=OneWay}" />
          <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.8"
                     Text="{x:Bind vm:ProcessFormat.Header('CPU', 'Cpu', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
        </StackPanel>
      </Button>
      <Button Grid.Column="3" Style="{StaticResource HeaderCellButton}" Tag="Memory" Click="OnSortHeaderClick"
              Background="{x:Bind svc:CellHeat.Brush(ViewModel.Inner.SystemMemoryPercent), Mode=OneWay}">
        <StackPanel>
          <TextBlock HorizontalAlignment="Right" FontSize="14"
                     Text="{x:Bind vm:ProcessFormat.HeaderPercent(ViewModel.Inner.SystemMemoryPercent), Mode=OneWay}" />
          <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.8"
                     Text="{x:Bind vm:ProcessFormat.Header('Arbeitsspeicher', 'Memory', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
        </StackPanel>
      </Button>
      <Button Grid.Column="4" Style="{StaticResource HeaderCellButton}" Tag="Disk" Click="OnSortHeaderClick"
              Background="{x:Bind svc:CellHeat.Brush(ViewModel.Inner.SystemDiskPercent), Mode=OneWay}">
        <StackPanel>
          <TextBlock HorizontalAlignment="Right" FontSize="14"
                     Text="{x:Bind vm:ProcessFormat.HeaderPercent(ViewModel.Inner.SystemDiskPercent), Mode=OneWay}" />
          <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.8"
                     Text="{x:Bind vm:ProcessFormat.Header('Datenträger', 'Disk', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
        </StackPanel>
      </Button>
      <!-- Header: echte Adapter-Auslastung (tm3-04). Zellen: echte Per-Prozess-Raten via ETW
           (tm2r-01); ohne Adminrechte liefert der Dienst nichts und alles bleibt ehrlich 0. -->
      <StackPanel Grid.Column="5" Margin="8,4" VerticalAlignment="Bottom"
                  Background="{x:Bind svc:CellHeat.Brush(ViewModel.Inner.SystemNetworkPercent), Mode=OneWay}">
        <TextBlock HorizontalAlignment="Right" FontSize="14"
                   Text="{x:Bind vm:ProcessFormat.HeaderPercent(ViewModel.Inner.SystemNetworkPercent), Mode=OneWay}" />
        <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.8" Text="Netzwerk" />
      </StackPanel>
      <Button Grid.Column="6" Style="{StaticResource HeaderCellButton}" Tag="Gpu" Click="OnSortHeaderClick"
              Background="{x:Bind svc:CellHeat.Brush(ViewModel.Inner.Totals.GpuPercent), Mode=OneWay}">
        <StackPanel>
          <TextBlock HorizontalAlignment="Right" FontSize="14"
                     Text="{x:Bind vm:ProcessFormat.HeaderPercent(ViewModel.Inner.Totals.GpuPercent), Mode=OneWay}" />
          <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.8"
                     Text="{x:Bind vm:ProcessFormat.Header('GPU', 'Gpu', ViewModel.Inner.SortColumn, ViewModel.Inner.SortDescending), Mode=OneWay}" />
        </StackPanel>
      </Button>
      <TextBlock Grid.Column="7" Margin="8,0,8,4" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" TextAlignment="Right" Text="Temperatur" />
      <TextBlock Grid.Column="8" Margin="8,0,8,4" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" TextAlignment="Right" Text="Leistung (W)" />
      <TextBlock Grid.Column="9" Margin="8,0,8,4" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" TextAlignment="Right" Text="Lüfter (RPM)" />
      <TextBlock Grid.Column="10" Margin="8,0,8,4" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" TextAlignment="Right" Text="Verlauf" />
    </Grid>

    <!-- Groups: Apps / Hintergrundprozesse / Windows-Prozesse, each with the real TM's left-side
         collapse chevron; state lives on the persistent section VM and survives ticks. -->
    <ScrollViewer Grid.Row="3">
      <ItemsControl ItemsSource="{x:Bind ViewModel.GroupedRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:Tm2ProcessGroupSection">
            <StackPanel Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
              <Button
                Margin="0,6,0,2"
                Padding="4,2"
                Background="Transparent"
                BorderThickness="0"
                Click="OnGroupToggleClick"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon FontSize="10" Glyph="&#xE70D;"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" />
                  <FontIcon FontSize="10" Glyph="&#xE76C;"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                  <TextBlock FontWeight="SemiBold" FontSize="12" Text="{Binding Header}" />
                </StackPanel>
              </Button>
              <ListView
                ItemsSource="{Binding}"
                SelectionChanged="OnSelectionChanged"
                SelectionMode="Single"
                ScrollViewer.VerticalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="vm:Tm2ProcessRowViewModel">
                    <Grid Background="Transparent">
                      <Grid.ContextFlyout>
                        <MenuFlyout>
                          <MenuFlyoutItem Click="OnEndTaskClick" Text="Task beenden" />
                          <MenuFlyoutItem Click="OnEndTreeClick" Text="Prozessstruktur beenden" />
                          <MenuFlyoutItem Click="OnEfficiencyClick" Text="Effizienzmodus" />
                          <MenuFlyoutSeparator />
                          <MenuFlyoutItem Click="OnOpenLocationClick" Text="Dateispeicherort öffnen" />
                          <MenuFlyoutItem Click="OnSearchOnlineClick" Text="Onlinesuche" />
                          <MenuFlyoutItem Click="OnNetConnectionsClick" Text="Netzwerkverbindungen" />
                        </MenuFlyout>
                      </Grid.ContextFlyout>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{StaticResource StatusWidth}" />
                        <ColumnDefinition Width="{StaticResource CpuWidth}" />
                        <ColumnDefinition Width="{StaticResource MemWidth}" />
                        <ColumnDefinition Width="{StaticResource DiskWidth}" />
                        <ColumnDefinition Width="{StaticResource NetWidth}" />
                        <ColumnDefinition Width="{StaticResource GpuWidth}" />
                        <ColumnDefinition Width="{StaticResource TempWidth}" />
                        <ColumnDefinition Width="{StaticResource WattWidth}" />
                        <ColumnDefinition Width="{StaticResource FanWidth}" />
                        <ColumnDefinition Width="{StaticResource TrendWidth}" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="4,3,8,3">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <!-- Real TM app rows expand to their window title; windowless rows keep
                               an empty 16px slot so names stay aligned. -->
                          <Button
                            Width="16"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnRowToggleClick"
                            Visibility="{x:Bind HasWindow, Mode=OneWay}">
                            <StackPanel>
                              <FontIcon FontSize="8" Glyph="&#xE70D;" Visibility="{x:Bind IsExpanded, Mode=OneWay}" />
                              <FontIcon FontSize="8" Glyph="&#xE76C;"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </StackPanel>
                          </Button>
                          <Border Width="16" Visibility="{Binding HasWindow, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                          <Image Width="16" Height="16" VerticalAlignment="Center"
                                 Source="{x:Bind svc:ProcessIcons.For(Pid)}" />
                          <TextBlock VerticalAlignment="Center" FontSize="12" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <!-- Indented window-title child row, like the expanded app row in the real TM. -->
                        <StackPanel Margin="40,2,0,0" Orientation="Horizontal" Spacing="8"
                                    Visibility="{x:Bind IsExpanded, Mode=OneWay}">
                          <Image Width="16" Height="16" VerticalAlignment="Center"
                                 Source="{x:Bind svc:ProcessIcons.For(Pid)}" />
                          <TextBlock VerticalAlignment="Center" FontSize="12" Opacity="0.9"
                                     Text="{x:Bind WindowTitle, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </StackPanel>
                      <!-- ponytail: Status-Zelle leer — Core hat keine Suspend-Detection; der echte
                           TM zeigt hier für die meisten Prozesse ebenfalls nichts. -->
                      <Border Grid.Column="2" Background="{x:Bind svc:CellHeat.Brush(CpuPercent), Mode=OneWay}">
                        <TextBlock Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.CellPercent(CpuPercent), Mode=OneWay}" />
                      </Border>
                      <Border Grid.Column="3" Background="{x:Bind svc:CellHeat.Brush(MemoryPercent), Mode=OneWay}">
                        <TextBlock Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.MemoryMb(WorkingSetBytes), Mode=OneWay}" />
                      </Border>
                      <Border Grid.Column="4" Background="{x:Bind svc:CellHeat.DiskBrush(IoReadBytesPerSecond, IoWriteBytesPerSecond), Mode=OneWay}">
                        <TextBlock Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.DiskRate(IoReadBytesPerSecond, IoWriteBytesPerSecond), Mode=OneWay}" />
                      </Border>
                      <Border Grid.Column="5" Background="{x:Bind svc:CellHeat.NetworkBrush(NetworkBytesPerSecond), Mode=OneWay}">
                        <TextBlock Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.NetworkRate(NetworkBytesPerSecond), Mode=OneWay}" />
                      </Border>
                      <Border Grid.Column="6" Background="{x:Bind svc:CellHeat.Brush(GpuPercent), Mode=OneWay}">
                        <TextBlock Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.CellPercent(GpuPercent), Mode=OneWay}" />
                      </Border>
                      <TextBlock Grid.Column="7" Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.Temperature(CpuTempCelsius), Mode=OneWay}" />
                      <TextBlock Grid.Column="8" Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.Power(PackageWattage), Mode=OneWay}" />
                      <TextBlock Grid.Column="9" Padding="8,3" VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                                 Text="{x:Bind vm:ProcessFormat.Fan(FanRpm), Mode=OneWay}" />
                      <Polyline
                        Grid.Column="10"
                        Width="120"
                        Height="20"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Points="{x:Bind views:SparklineRender.Points(CpuHistory, 120, 20), Mode=OneWay}"
                        Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                        StrokeThickness="1" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Page>
