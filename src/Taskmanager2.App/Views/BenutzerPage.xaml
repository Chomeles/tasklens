<Page
  x:Class="Taskmanager2.App.Views.BenutzerPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:TaskLens.Core.ViewModels">

  <Grid Margin="24,12" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Real TM page header: big title left, like every Win11 TM page. -->
    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Text="Benutzer" />

    <!-- Degradation as data: access denied shows a banner instead of throwing (plan-tm2.md §2). -->
    <InfoBar
      Grid.Row="1"
      IsClosable="False"
      IsOpen="{x:Bind ViewModel.ShowBanner, Mode=OneWay}"
      Message="{x:Bind ViewModel.BannerText, Mode=OneWay}"
      Severity="Warning" />

    <!-- Fixed order: nach Sitzungs-ID — keine Sortier-UI. Read-only: beobachten, nie trennen
         oder abmelden (plan-tm2.md §2). -->
    <Grid Grid.Row="2" Padding="12,0" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="100" />
        <ColumnDefinition Width="130" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" Text="Benutzer" />
      <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" Text="Sitzungs-ID" />
      <TextBlock Grid.Column="2" VerticalAlignment="Bottom" FontSize="12" Opacity="0.8" Text="Status" />
    </Grid>

    <InfoBar
      Grid.Row="3"
      CloseButtonClick="OnErrorClosed"
      IsOpen="{x:Bind ViewModel.HasActionError, Mode=OneWay}"
      Message="{x:Bind ViewModel.LastActionError, Mode=OneWay}"
      Severity="Error"
      Title="Sitzungsaktion fehlgeschlagen" />

    <ListView
      Grid.Row="4"
      ItemsSource="{x:Bind ViewModel.Rows}"
      SelectionChanged="OnSelectionChanged"
      SelectionMode="Single">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="12,2" />
          <Setter Property="MinHeight" Value="0" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:Tm2UserRowViewModel">
          <Grid Background="Transparent" ColumnSpacing="8">
            <Grid.ContextFlyout>
              <MenuFlyout>
                <MenuFlyoutItem Click="OnDisconnectClick" Text="Verbindung trennen" />
                <MenuFlyoutItem Click="OnLogoffClick" Text="Abmelden" />
              </MenuFlyout>
            </Grid.ContextFlyout>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="260" />
              <ColumnDefinition Width="100" />
              <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind UserName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind SessionIdText}" TextAlignment="Right" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind State, Mode=OneWay}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Page>
